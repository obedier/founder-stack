# Amazon SES — backend env. NEVER commit real values or ship these to a client.
# Sender is per-app config: set SES_FROM to a verified SES identity for THIS app.

AWS_REGION=us-east-1
SES_FROM=noreply@yourdomain.com   # must be a verified SES identity in AWS_REGION

# Credentials: local/dev only. In Lambda/ECS/EC2 use an IAM role instead and omit these.
# Prefer a dedicated least-privilege send user (see iam-send-policy.json), not admin/SSO keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=            # only for temporary/STS credentials
